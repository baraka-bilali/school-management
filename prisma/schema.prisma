generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int       @id @default(autoincrement())
  name              String
  email             String    @unique
  password          String
  role              User_role @default(ELEVE)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  nom               String?
  prenom            String?
  telephone         String?
  fonction          String?
  schoolId          Int?
  dateCreation      DateTime? @default(now())
  temporaryPassword Boolean   @default(false)
  isActive          Boolean   @default(true)
  createdSchools    School[]  @relation("SchoolsCreated")
  student           Student?
  teacher           Teacher?
  school            School?   @relation("SchoolAdmins", fields: [schoolId], references: [id])

  @@index([schoolId])
}

model AcademicYear {
  id              Int                @id @default(autoincrement())
  name            String             @unique
  current         Boolean            @default(false)
  startDate       DateTime?
  endDate         DateTime?
  enrollments     Enrollment[]
  tarifications   Tarification[]
  receiptCounters ReceiptCounter[]
  assignments     CourseAssignment[]
  slots           ScheduleSlot[]
}

model Class {
  id            Int                @id @default(autoincrement())
  name          String
  level         String
  createdAt     DateTime           @default(now())
  letter        String
  section       String
  stream        String?
  schoolId      Int
  school        School             @relation(fields: [schoolId], references: [id])
  enrollments   Enrollment[]
  tarifications Tarification[]
  assignments   CourseAssignment[]
  slots         ScheduleSlot[]

  @@unique([name, schoolId])
  @@index([section])
  @@index([level])
  @@index([schoolId])
  @@index([section, level, letter])
}

model Student {
  id          Int          @id @default(autoincrement())
  userId      Int          @unique
  code        String       @unique
  lastName    String
  middleName  String
  firstName   String
  gender      String
  birthDate   DateTime
  enrollments Enrollment[]
  paiements   Paiement[]
  user        User         @relation(fields: [userId], references: [id])

  @@index([lastName])
  @@index([code])
  @@index([lastName, firstName])
}

model Teacher {
  id          Int                @id @default(autoincrement())
  userId      Int                @unique
  lastName    String
  middleName  String
  firstName   String
  gender      String
  birthDate   DateTime
  specialty   String?
  phone       String?
  hiredAt     DateTime?          @default(now())
  user        User               @relation(fields: [userId], references: [id])
  payments    TeacherPayment[]
  assignments CourseAssignment[]

  @@index([lastName])
  @@index([specialty])
  @@index([lastName, firstName])
}

model Enrollment {
  id         Int              @id @default(autoincrement())
  studentId  Int
  classId    Int
  yearId     Int
  status     EnrollmentStatus @default(ACTIVE)
  exitReason String?
  class      Class            @relation(fields: [classId], references: [id])
  student    Student          @relation(fields: [studentId], references: [id])
  year       AcademicYear     @relation(fields: [yearId], references: [id])
  paiements  Paiement[]

  @@unique([studentId, classId, yearId])
  @@index([classId], map: "Enrollment_classId_fkey")
  @@index([yearId], map: "Enrollment_yearId_fkey")
}

model School {
  id                          Int               @id @default(autoincrement())
  nomEtablissement            String
  typeEtablissement           TypeEtablissement @default(PRIVE)
  niveauEnseignement          String?           @db.LongText
  codeEtablissement           String?           @unique
  anneeCreation               Int?
  slogan                      String?
  logoUrl                     String?
  statutJuridique             String?
  rccm                        String?
  idNat                       String?
  nif                         String?
  agrementMinisteriel         String?
  dateAgrement                DateTime?
  ministereTutelle            String?
  statutsReglements           String?
  responsableLegal            String?
  pieceIdentiteResponsable    String?
  adresse                     String
  ville                       String
  province                    String
  pays                        String            @default("RDC")
  telephone                   String
  email                       String
  siteWeb                     String?
  directeurNom                String
  directeurTelephone          String
  directeurEmail              String?
  secretaireAcademique        String?
  comptable                   String?
  personnelAdministratifTotal Int?
  cycles                      String?
  nombreClasses               Int?
  nombreEleves                Int?
  nombreEnseignants           Int?
  langueEnseignement          String?
  programmes                  String?
  calendrierScolaire          String?           @db.LongText
  joursOuverture              String?
  domaine                     String?
  identifiantInterne          String            @unique @default(uuid())
  etatCompte                  EtatCompte        @default(EN_ATTENTE)
  dateInscription             DateTime          @default(now())
  derniereMiseAJour           DateTime          @updatedAt
  creeParId                   Int?
  modifieParId                Int?
  dateCreation                DateTime          @default(now())
  dateModification            DateTime          @updatedAt
  dateDebutAbonnement         DateTime?
  dateFinAbonnement           DateTime?
  periodeAbonnement           String?
  planAbonnement              String?
  typePaiement                String?
  montantPaye                 Float?
  createdBy                   User?             @relation("SchoolsCreated", fields: [creeParId], references: [id])
  admins                      User[]            @relation("SchoolAdmins")
  classes                     Class[]

  @@index([codeEtablissement])
  @@index([email])
  @@index([creeParId], map: "School_creeParId_fkey")
}

model Notification {
  id        Int              @id @default(autoincrement())
  type      NotificationType
  message   String           @db.Text
  schoolId  Int?
  userId    Int?
  isRead    Boolean          @default(false)
  daysLeft  Int?
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([schoolId, isRead])
  @@index([createdAt])
}

// ============================================================
// MODULE FRAIS SCOLAIRES
// ============================================================

model TypeFrais {
  id            Int             @id @default(autoincrement())
  code          String          @unique
  nom           String
  description   String?         @db.Text
  schoolId      Int
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  tarifications Tarification[]

  @@unique([schoolId, code])
  @@index([schoolId])
}

model Tarification {
  id           Int          @id @default(autoincrement())
  typeFraisId  Int
  yearId       Int
  classId      Int?
  montant      Float
  description  String?      @db.Text
  schoolId     Int
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  typeFrais    TypeFrais    @relation(fields: [typeFraisId], references: [id])
  year         AcademicYear @relation(fields: [yearId], references: [id])
  class        Class?       @relation(fields: [classId], references: [id])
  echeances    Echeance[]
  paiements    Paiement[]

  @@unique([typeFraisId, yearId, classId, schoolId])
  @@index([schoolId])
  @@index([yearId])
  @@index([classId])
  @@index([typeFraisId])
}

model Echeance {
  id              Int          @id @default(autoincrement())
  tarificationId  Int
  nom             String
  montant         Float
  dateEcheance    DateTime
  ordre           Int          @default(1)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  tarification    Tarification @relation(fields: [tarificationId], references: [id], onDelete: Cascade)

  @@index([tarificationId])
  @@index([dateEcheance])
}

model Paiement {
  id               Int                    @id @default(autoincrement())
  numeroRecu       String                 @unique
  enrollmentId     Int
  studentId        Int
  tarificationId   Int
  montant          Float
  datePaiement     DateTime               @default(now())
  modePaiement     ModePaiement           @default(CASH)
  reference        String?
  notes            String?                @db.Text
  recuPdfPath      String?
  schoolId         Int
  createdBy        Int
  isAnnule         Boolean                @default(false)
  motifAnnulation  String?                @db.Text
  annulePar        Int?
  dateAnnulation   DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  enrollment       Enrollment             @relation(fields: [enrollmentId], references: [id])
  student          Student                @relation(fields: [studentId], references: [id])
  tarification     Tarification           @relation(fields: [tarificationId], references: [id])
  modifications    PaiementModification[]

  @@index([schoolId])
  @@index([studentId])
  @@index([enrollmentId])
  @@index([tarificationId])
  @@index([numeroRecu])
  @@index([datePaiement])
  @@index([schoolId, datePaiement])
}

model PaiementModification {
  id              Int      @id @default(autoincrement())
  paiementId      Int
  champModifie    String
  ancienneValeur  String   @db.Text
  nouvelleValeur  String   @db.Text
  modifiePar      Int
  motif           String?  @db.Text
  createdAt       DateTime @default(now())
  paiement        Paiement @relation(fields: [paiementId], references: [id])

  @@index([paiementId])
  @@index([createdAt])
}

model ReceiptCounter {
  id        Int          @id @default(autoincrement())
  schoolId  Int
  yearId    Int
  counter   Int          @default(0)
  year      AcademicYear @relation(fields: [yearId], references: [id])

  @@unique([schoolId, yearId])
}

// ============================================================
// MODULE TRÉSORERIE — SALAIRES & DÉPENSES
// ============================================================

model TeacherPayment {
  id            Int          @id @default(autoincrement())
  teacherId     Int
  schoolId      Int
  montant       Float
  type          PaymentType  @default(SALAIRE)
  mois          String       // ex: "2026-04"
  description   String?      @db.Text
  modePaiement  ModePaiement @default(CASH)
  reference     String?
  datePaiement  DateTime     @default(now())
  createdBy     Int
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  teacher       Teacher      @relation(fields: [teacherId], references: [id])

  @@index([schoolId])
  @@index([teacherId])
  @@index([datePaiement])
  @@index([schoolId, mois])
}

model SchoolExpense {
  id            Int             @id @default(autoincrement())
  schoolId      Int
  categorie     ExpenseCategory @default(AUTRE)
  motif         String          @db.Text
  montant       Float
  beneficiaire  String?
  modePaiement  ModePaiement    @default(CASH)
  reference     String?
  dateDepense   DateTime        @default(now())
  createdBy     Int
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([schoolId])
  @@index([dateDepense])
  @@index([schoolId, categorie])
}

enum PaymentType {
  SALAIRE
  PRIME
  BONUS
  AVANCE
  AUTRE
}

enum ExpenseCategory {
  FOURNITURES
  EQUIPEMENT
  MAINTENANCE
  TRANSPORT
  COMMUNICATION
  EVENEMENT
  AUTRE
}

enum User_role {
  ADMIN
  ELEVE
  COMPTABLE
  PROFESSEUR
  DIRECTEUR_DISCIPLINE
  DIRECTEUR_ETUDES
  SUPER_ADMIN
}

enum EnrollmentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  DROPPED_OUT
  EXPELLED
}

enum TypeEtablissement {
  PUBLIC
  PRIVE
  SEMI_PRIVE
}

enum EtatCompte {
  ACTIF
  EN_ATTENTE
  SUSPENDU
}

enum NotificationType {
  SUBSCRIPTION_EXPIRING_15_DAYS
  SUBSCRIPTION_EXPIRING_10_DAYS
  SUBSCRIPTION_EXPIRING_5_DAYS
  SUBSCRIPTION_EXPIRING_2_DAYS
  SUBSCRIPTION_EXPIRING_1_DAY
  SUBSCRIPTION_EXPIRED
}

enum ModePaiement {
  CASH
  VIREMENT
  MOBILE_MONEY
  CHEQUE
  AUTRE
}

// ============================================================
// MODULE GESTION D'HORAIRES
// ============================================================

model Subject {
  id             Int                @id @default(autoincrement())
  name           String             // ex: Mathématiques
  code           String             // ex: MATH
  description    String?            @db.Text
  color          String?            // ex: #4f46e5
  coefficient    Float              @default(1)
  maxWeeklyHours Int                @default(5)
  schoolId       Int
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  assignments    CourseAssignment[]

  @@unique([schoolId, code])
  @@index([schoolId])
}

model CourseAssignment {
  id            Int            @id @default(autoincrement())
  subjectId     Int
  teacherId     Int
  classId       Int
  yearId        Int
  weeklyHours   Float          // heures allouées par semaine
  maxDailyHours Float?         // plafond horaire par jour
  schoolId      Int
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subject       Subject        @relation(fields: [subjectId], references: [id])
  teacher       Teacher        @relation(fields: [teacherId], references: [id])
  class         Class          @relation(fields: [classId], references: [id])
  year          AcademicYear   @relation(fields: [yearId], references: [id])
  slots         ScheduleSlot[]

  @@unique([subjectId, classId, yearId, schoolId])
  @@index([schoolId])
  @@index([teacherId])
  @@index([classId])
  @@index([yearId])
}

model ScheduleSlot {
  id           Int              @id @default(autoincrement())
  assignmentId Int
  classId      Int
  dayOfWeek    Int              // 1=Lundi … 6=Samedi
  startTime    String           // "08:00"
  endTime      String           // "09:00"
  room         String?
  schoolId     Int
  yearId       Int
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  assignment   CourseAssignment @relation(fields: [assignmentId], references: [id])
  class        Class            @relation(fields: [classId], references: [id])
  year         AcademicYear     @relation(fields: [yearId], references: [id])

  @@index([schoolId])
  @@index([classId])
  @@index([assignmentId])
  @@index([dayOfWeek])
  @@index([yearId])
}

model ScheduleBreak {
  id        Int       @id @default(autoincrement())
  name      String    // "Récréation du matin"
  type      BreakType @default(RECREATION)
  startTime String    // "10:00"
  endTime   String    // "10:20"
  duration  Int       // durée en minutes
  section   String?   // "Primaire", "Secondaire" ou null = tous
  schoolId  Int
  dayOfWeek Int?      // null = tous les jours scolaires
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([schoolId])
}

enum BreakType {
  RECREATION
  PAUSE_DEJEUNER
  INTER_COURS
  DEBUT_VACATION
  FIN_VACATION
}
